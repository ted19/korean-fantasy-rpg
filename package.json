{
  "name": "korean-fantasy-rpg",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others -n server,client \"npm run server:dev\" \"npm run client\"",
    "server": "cd server && node index.js",
    "server:dev": "cd server && npx nodemon index.js",
    "client": "cd client && npm start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14"
  }
}
